	<div id="popmake-423" class="pum-container popmake theme-414 pum-responsive pum-responsive-medium responsive size-medium main-container">

				
				
		
				<div class="pum-content popmake-content" tabindex="0">
			<div data-parent="true" class="vc_row row-container" id="row-unique-6"><div class="row limit-width row-parent"><div class="wpb_row row-inner"><div class="wpb_column pos-top pos-center align_left column_parent col-lg-12 single-internal-gutter"><div class="uncol style-light"  ><div class="uncoltable"><div class="uncell no-block-padding" ><div class="uncont" ><div class="icon-box icon-box-top  icon-media-image" ><div class="icon-box-icon fa-container" style="width:60px;"><span class="text-accent-color btn-disable-hover"><img decoding="async" class=" srcset-async srcset-auto" src="https://www.andromeda-shipping.com/wp-content/uploads/2024/10/technical-manag-1.png" width="200" height="200" alt=""  data-no-bp="" data-bp="720,1032" data-uniqueid="608-513689" data-guid="https://www.andromeda-shipping.com/wp-content/uploads/2024/10/technical-manag-1.png" data-path="2024/10/technical-manag-1.png" data-width="200" data-height="200" data-singlew="12" data-singleh="" data-crop="" loading="lazy" data-srcset="https://www.andromeda-shipping.com/wp-content/uploads/2024/10/technical-manag-1.png 200w, https://www.andromeda-shipping.com/wp-content/uploads/2024/10/technical-manag-1-150x150.png 150w" srcset="data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAwIiBoZWlnaHQ9IjIwMCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNMCAwaDF2MUgweiIgZmlsbD0ibm9uZSIgZmlsbC1ydWxlPSJldmVub2RkIi8+PC9zdmc+" /></span></div><div class="icon-box-content"><div class="icon-box-heading icon-box-fa-1x"><h3 class="h4 font-weight-600">TECHNICAL MANAGEMENT</h3></div><p class="p1"><span class="s1">We offer tailor-made technical services designed to suit your specific requirements, including monitoring and recording of CO2 emissions, plan approvals, building supervision, sale &amp; delivery and full operation management incorporating crewing, purchasing, insurance, surveys and HQSE.</span></p>
<p class="p1"><span class="s1">We allocate Technical Superintendents to monitor continually through:</span></p>
<ul class="ul1">
<li class="li2"><span class="s3">Regular condition assessments and performance monitoring</span></li>
<li class="li2"><span class="s3">Planned and projected maintenance</span></li>
<li class="li2"><span class="s3">Dry dock planning and supervision</span></li>
<li class="li2"><span class="s3">Surveys, certification and vetting</span></li>
</ul>
</div></div></div></div></div></div></div><script id="script-row-unique-6" data-row="script-row-unique-6" type="text/javascript" class="vc_controls">UNCODE.initRow(document.getElementById("row-unique-6"));</script></div></div></div>
		</div>

				
							<button type="button" class="pum-close popmake-close" aria-label="Close">
			Close			</button>
		
	</div>

</div>
